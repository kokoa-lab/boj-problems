      </mstyle>
    </mrow>
    <annotation encoding="application/x-tex">{\displaystyle x-1&lt;m\leq x\leq n&lt;x+1.}</annotation>
  </semantics>
</math></span><img src="https://wikimedia.org/api/rest_v1/media/math/render/svg/c9f617ac56046d25e1b70f934c69702ec3e1a696" class="mwe-math-fallback-image-inline mw-invert skin-invert" aria-hidden="true" style="vertical-align: -0.505ex; width:28.471ex; height:2.343ex;" alt="{\displaystyle x-1&lt;m\leq x\leq n&lt;x+1.}"></span></dd></dl>
<p>where <span class="mwe-math-element mwe-math-element-inline"><span class="mwe-math-mathml-inline mwe-math-mathml-a11y" style="display: none;"><math xmlns="http://www.w3.org/1998/Math/MathML"  alttext="{\displaystyle \lfloor x\rfloor =m}">
  <semantics>
    <mrow class="MJX-TeXAtom-ORD">
      <mstyle displaystyle="true" scriptlevel="0">
        <mo fence="false" stretchy="false">&#x230A;<!-- ⌊ --></mo>
