      </mstyle>
    </mrow>
    <annotation encoding="application/x-tex">{\displaystyle \lfloor x\rfloor =m}</annotation>
  </semantics>
</math></span><img src="https://wikimedia.org/api/rest_v1/media/math/render/svg/867789ab49fcd1f640b4d34be1b3d97142f0478d" class="mwe-math-fallback-image-inline mw-invert skin-invert" aria-hidden="true" style="vertical-align: -0.838ex; width:8.533ex; height:2.843ex;" alt="{\displaystyle \lfloor x\rfloor =m}"></span>&#160;and <span class="mwe-math-element mwe-math-element-inline"><span class="mwe-math-mathml-inline mwe-math-mathml-a11y" style="display: none;"><math xmlns="http://www.w3.org/1998/Math/MathML"  alttext="{\displaystyle \lceil x\rceil =n}">
  <semantics>
