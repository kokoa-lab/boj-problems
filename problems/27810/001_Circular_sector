<div class="mw-heading mw-heading2"><h2 id="Perimeter">Perimeter</h2><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="/w/index.php?title=Circular_sector&amp;action=edit&amp;section=3" title="Edit section: Perimeter"><span>edit</span></a><span class="mw-editsection-bracket">]</span></span></div>
