        if res == &#039; &#039; || res == &#039;\n&#039; {
            if res == &#039;\r&#039; {
                continue;
            }
            return buf;
        }
        buf.push(res);
    }
}

fn main() {
    let n = read().parse::&lt;i32&gt;().unwrap();
