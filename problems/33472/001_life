		$(window).on('scroll', function() {
			secSep();
			floatMotion();

			if($(window).scrollTop() <= 0) {
				$('html').addClass('scroll-disable');
			}

			if($('html').hasClass('life02')) {
				setTimeout(function() {
					$('.quick-2dep-list').addClass('on');
