		function floatMotion() {
			if ($('header#header').hasClass('scroll')) {
				$('.float-wrap').removeClass('top');
				$('.quick-wrap').addClass('ani')
			} else {
				$('.float-wrap').addClass('top');
				$('.quick-wrap').removeClass('ani')
			}

			if ($(window).width() > 1199) {
				var val = $(document).height() - ($(window).height() / 2) - $('footer#footer').outerHeight() - 750;
				var h = $(document).height() - $('footer#footer').outerHeight() - 380;

				if ($(window).scrollTop() >= val) {
					$('.float-wrap').addClass('fixed')
					$('.float-wrap').css('top', h);
				} else {
					$('.float-wrap').removeClass('fixed')
					$('.float-wrap').css('top', 'auto');
				}
			} else {
				$('.float-wrap').removeClass('fixed')
				$('.float-wrap').css('top', 'auto');
			}

			var val02 = $(document).height() - ($(window).height() / 2) - $('footer#footer').outerHeight() - 600;
			var h02 = $(document).height() - $('footer#footer').outerHeight() - 200;

			if ($(window).scrollTop() >= val02) {
				$('.quick-wrap').addClass('fixed')
				$('.quick-wrap').css('top', h02);
			} else {
				$('.quick-wrap').removeClass('fixed')
				$('.quick-wrap').css('top', 'auto');
			}

			$('.quick-wrap button').on('click',function() {
				var target = $(this).data('target');
				if($(this).parent().hasClass('quick-2dep-list')) {
					if (target == 'work01') {
						$(window).scrollTop($(window).height());
					} else if (target == 'work02') {
						if ($(window).width() > 1199) {
							// $(window).scrollTop($(window).outerHeight()+($('.sc01 .work-list').outerWidth()-$(window).width()/2)+$('.sc02').outerWidth());
						} else {
							$(window).scrollTop($('.sc02').offset().top);
						}
					}
					return;
				} else if (target == 'work') {
					var offset = $(window).height();
				} else {
					var offset = $('section.' + target).offset().top;
				}
				$(window).scrollTop(offset);
			})

			if ($('html').hasClass('life01') || $('html').hasClass('life02')) {
				$('.quick-wrap button[data-target="work"]').addClass('active')
				// $('.quick-list .quick-2dep-list').fadeIn();
			} else {
				$('.quick-wrap button[data-target="work"]').removeClass('active')
				// $('.quick-list .quick-2dep-list').fadeOut();
			}

			if ($('html').hasClass('life03')) {
				$('.quick-wrap button[data-target="wellbeing"]').addClass('active')
			} else {
				$('.quick-wrap button[data-target="wellbeing"]').removeClass('active')
			}

			if ($('html').hasClass('life04')) {
				$('.quick-wrap button[data-target="career"]').addClass('active')
			} else {
				$('.quick-wrap button[data-target="career"]').removeClass('active')
			}

			if ($('html').hasClass('life05')) return;

			var selW = $('.quick-list .active').outerWidth();
			var selP = $('.quick-list .active').position();

			$('.quick-list .bar').css({'left':selP.left, 'width': selW});
		}

		// work slide
		function workSlide() {
			var workOptions = {
				swipeToSlide: true,
				draggable: true,
				dots: true,
				arrows: false,
				variableWidth: true,
				touchThreshold: 5000,
				centerMode: true,
				responsive: [{
					breakpoint: 767,
					settings: {
						centerMode: false,
						// variableWidth: false,
					}
				}]
			};

			if ($(window).width() > 1199) {
				$('.work-list').filter('.slick-initialized').slick('unslick');
				$('.work-list').each(function() {
					var listN = $(this).find('li').length;
					var listW = (307 * listN) + (32 * (listN - 1));

					$(this).css('width',listW);
				})
			} else {
				$('.work-list').css('width','auto');
				$('.work-list').not('.slick-initialized').slick(workOptions);
				$('.work-list').slick('setPosition');
			}
		}

		function visualMotion() {
			var time = 200,
				time02 = 400;

			// pc
			$(window).bind('wheel', function(event) {
				if (event.originalEvent.wheelDelta > 0 || event.originalEvent.detail < 0) {
					if (!$('html').hasClass('menu-open') && $('#layerFit').css('display') == 'none') {
						moveUp();
					}
				} else {
					if (!$('html').hasClass('menu-open') && $('#layerFit').css('display') == 'none') {
						moveDown();
					}
				}
			});

			// mobile
			var startX, startY, endX, endY;

			$(window).on('touchstart', function(event) {
				startX = event.originalEvent.changedTouches[0].screenX;
				startY = event.originalEvent.changedTouches[0].screenY;
			});

			$(window).on('touchend', function(event) {
				endX = event.originalEvent.changedTouches[0].screenX;
				endY = event.originalEvent.changedTouches[0].screenY;

				if (startY - endY > 50) {
					if (!$('html').hasClass('menu-open') && $('#layerFit').css('display') == 'none') {
						moveDown();
					}
				} else if (endY - startY > 50) {
					if (!$('html').hasClass('menu-open') && $('#layerFit').css('display') == 'none') {
						moveUp();
					}
				}
			});

			function moveDown() {
				if ($(window).scrollTop() == 0) {
	                if ($('html').hasClass('visual-intro')) {
	                    setTimeout(function() {
	                        $('html').removeClass('visual-intro').addClass('visual-ani');
	                    }, time);
	                }

	                if ($('html').hasClass('visual-ani') && $('html').hasClass('scroll-disable')) {
	                    setTimeout(function() {
	                        $('html').removeClass('scroll-disable');
	                    }, time02);
	                }

	            }
			}

			function moveUp() {
				if ($(window).scrollTop() == 0) {
	                if ($('html').hasClass('visual-ani') && $('html').hasClass('scroll-disable')) {
	                    setTimeout(function() {
	                        $('html').addClass('visual-intro').removeClass('visual-ani');
	                    }, time02);
	                }

	                if ($('html').hasClass('visual-ani')) {
	                    setTimeout(function() {
	                        $('html').addClass('scroll-disable');
	                    }, time);
	                }

	            }
			}
		}

		function secSep() {
			$('section').each(function(i) {
				var h = $('section').eq(i).outerHeight(),
					t = $('section').eq(i).offset().top;

				if ($(window).scrollTop() + $(window).height() > t + $(window).height() / 2) {
					$('html').removeClass('life01 life02 life03 life04 life05')
					$('html').addClass('life0' + (i + 1))
				}
