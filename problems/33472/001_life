			// 		}
			// })
			$('.sc-wrap').each(function(i) {
					if ($(window).width() > 1199) {
						var h = $('.life-con.work').outerHeight(),
						t = $('.life-con.work').offset().top,
						l = $('.sc-wrap').eq(i).offset().left;

						if ($(window).scrollTop() + $(window).height() > t + $(window).height() / 2) {
							if ($(window).width() / 2 > l) {
								$('html').removeClass('work01 work02')
								$('html').addClass('work0' + (i + 1))
							}
						}
					} else {
						var h = $('.sc-wrap').eq(i).outerHeight(),
							t = $('.sc-wrap').eq(i).offset().top;

						if ($(window).scrollTop() + $(window).height() > t + $(window).height() / 2) {
							$('html').removeClass('work01 work02')
							$('html').addClass('work0' + (i + 1))
						}
					}
			})

			if ($(window).width() > 1199) {
				if ($('.sc-wrap.sc02').offset().left == 0) {
					$('.sc-wrap.sc01').css('background-color','transparent');
				} else {
					$('.sc-wrap.sc01').css('background-color','#fff');
				}
			}
		}
	});

