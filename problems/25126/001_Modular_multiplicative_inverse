  </semantics>
</math></span><img src="https://wikimedia.org/api/rest_v1/media/math/render/svg/5224c3ba00b60cd7a8c3b5fc19e1308fa309dbcd" class="mwe-math-fallback-image-inline mw-invert skin-invert" aria-hidden="true" style="vertical-align: -0.838ex; width:21.796ex; height:3.343ex;" alt="{\displaystyle a^{\phi (m)}\equiv 1{\pmod {m}},}"></span></dd></dl>
<p>where <span class="mwe-math-element mwe-math-element-inline"><span class="mwe-math-mathml-inline mwe-math-mathml-a11y" style="display: none;"><math xmlns="http://www.w3.org/1998/Math/MathML"  alttext="{\displaystyle \phi }">
  <semantics>
