<li><span class="texhtml"><i>b</i><span class="nowrap"><span style="display:inline-block;margin-bottom:-0.3em;vertical-align:-0.4em;line-height:1.2em;font-size:80%;text-align:left"><sup style="font-size:inherit;line-height:inherit;vertical-align:baseline">−1</sup><br /><sub style="font-size:inherit;line-height:inherit;vertical-align:baseline"><i>i</i>−1</sub></span></span> = <i>b</i><span class="nowrap"><span style="display:inline-block;margin-bottom:-0.3em;vertical-align:-0.4em;line-height:1.2em;font-size:80%;text-align:left"><sup style="font-size:inherit;line-height:inherit;vertical-align:baseline">−1</sup><br /><sub style="font-size:inherit;line-height:inherit;vertical-align:baseline"><i>i</i></sub></span></span><i>a<sub>i</sub></i></span>.</li></ul></li>
