<div class="mw-heading mw-heading2"><h2 id="Further_refinements">Further refinements</h2><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="/w/index.php?title=Lagrange%27s_four-square_theorem&amp;action=edit&amp;section=9" title="Edit section: Further refinements"><span>edit</span></a><span class="mw-editsection-bracket">]</span></span></div>
