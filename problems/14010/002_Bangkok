<div class="mw-heading mw-heading3"><h3 id="Districts">Districts</h3><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="/w/index.php?title=Bangkok&amp;action=edit&amp;section=8" title="Edit section: Districts"><span>edit</span></a><span class="mw-editsection-bracket">]</span></span></div>
