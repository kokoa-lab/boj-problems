<div class="mw-heading mw-heading2"><h2 id="Twindragon">Twindragon</h2><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="/w/index.php?title=Dragon_curve&amp;action=edit&amp;section=5" title="Edit section: Twindragon"><span>edit</span></a><span class="mw-editsection-bracket">]</span></span></div>
