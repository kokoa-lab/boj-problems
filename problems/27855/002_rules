(function () {
  function hasUserConsented() {
    try {
      // Shopify native consent (preferred)
      if (window.Shopify && window.Shopify.customerPrivacy) {
        var consent = window.Shopify.customerPrivacy.getTrackingConsent?.();

        if (consent) {
          // if any value is explicitly set, user already interacted
          return (
            consent.marketing === "yes" ||
            consent.marketing === "no" ||
            consent.analytics === "yes" ||
            consent.analytics === "no"
          );
        }
      }

      // fallback (localStorage flag)
      return localStorage.getItem("cookie_consent_set") === "true";
    } catch (e) {
      return false;
    }
  }

  function hideBanner() {
    var banner = document.getElementById("shopify-pc__banner");
    if (banner) {
      banner.style.display = "none";
    }
  }

  function markConsentGiven() {
    try {
      localStorage.setItem("cookie_consent_set", "true");
    } catch (e) {}
  }

  function init() {
    // Hide immediately if already consented
    if (hasUserConsented()) {
      hideBanner();
    }

    // Attach click listeners
    document.addEventListener("click", function (e) {
      var target = e.target;

      if (!target) return;

      if (
        target.id === "shopify-pc__banner__btn-accept" ||
        target.id === "shopify-pc__banner__btn-decline"
      ) {
        markConsentGiven();

        // allow Shopify to process, then hide
        setTimeout(function () {
          hideBanner();
        }, 300);
      }
    });
  }

  // Run after DOM ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
})();
</script>
