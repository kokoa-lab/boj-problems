    return;
  }

  function startWidget() {
    // guard again right before start
    if (document.getElementById('google-merchantwidget-iframe-wrapper')) return;

    if (window.merchantwidget && typeof window.merchantwidget.start === 'function') {
      window.merchantwidget.start({
           position: 'LEFT_BOTTOM',
          sideMargin: 25,
          bottomMargin: 80
      });
    } else {
      console.warn('merchantwidget.start not available');
    }
  }

  if (window.merchantwidget && typeof window.merchantwidget.start === 'function') {
    startWidget();
    return;
  }

  if (document.querySelector('script[data-gmc-merchantwidget="1"]')) return;

  var s = document.createElement('script');
  s.async = true;
  s.src = 'https://www.gstatic.com/shopping/merchant/merchantwidget.js';
  s.setAttribute('data-gmc-merchantwidget', '1');
  s.addEventListener('load', startWidget);
  s.addEventListener('error', function (e) { console.warn('Failed to load merchantwidget.js', e); });
  document.head.appendChild(s);
})();
</script>
