}

long long score_table[22] = {
    0, 1, 2, 4, 8,
    16, 32, 64, 128, 256,
    343, 486, 512, 666, 1024,
    1248, 1557, 1717, 2023, 2320,
    2780, 2790,
};

int get_digit(char c){
    if(c <= '9') return c - 48;
    return c - 87;
}

char put_digit(int x){
    if(x <= 9) return (char)(x + 48);
    return (char)(x + 87);
}

std::string get_next_state(std::string state, int mv, int turn){
    std::string prev_s = state.substr(mv * 2, 2);
    int prev_n = get_digit(prev_s[0]) * 16 + get_digit(prev_s[1]);
    std::string new_s = "";
    for(int i = 6; i >= 0; i--){
        if((prev_n >> i) & 1){
            if(i == 6){
                // invalid move: dropping in filled column
                return "-";
            }
            int new_n = prev_n | (1 << (i + 1));
            if(!turn) new_n ^= (1 << i);
            new_s += put_digit(new_n >> 4);
            new_s += put_digit(new_n & 15);
            break;
        }
    }
    return state.substr(0, mv * 2) + new_s + state.substr((mv + 1) * 2);
}

int main(){
    init();
    std::string state = "01010101010101";
    int optimal_move_count = 0;
    printf("+-----------------------------------------------------+\n");
    printf("| Interactive Grader for BOJ #27900                   |\n");
    printf("+-----------------------------------------------------+\n");
    printf("| You should input the AI move (interactively)        |\n");
    printf("| If player won, write 0.                             |\n");
    printf("| If player's move is not optimal, write -1.          |\n");
    printf("| Otherwise, write your best move. (as second player) |\n");
    printf("+-----------------------------------------------------+\n");
    for(int i = 0; i < 21; i++){
        int x = next_move(state);
        printf("Previous State = %s, Your Program's Move = %d\n", state.c_str(), x);
        if(x < 0 || x > 7){
            printf("Your move (%d) is invalid", x);
            optimal_move_count = 0;
            break;
        }
        if(x == 0){
            printf("You resigned on move %d\n", i + 1);
            break;
        }
        state = get_next_state(state.c_str(), x - 1, 0);
        if(state == "-"){
            printf("You tried to drop piece in filled column.\n");
            break;
        }
        printf("New State = %s\n", state.c_str());
        printf("INPUT the AI move: ");
        int qry;
        scanf("%d", &qry);
        if(qry == 0){
            optimal_move_count = 21;
            break;
        }
        else if(qry == -1){
            break;
        }
        else{
            optimal_move_count++;
            state = get_next_state(state.c_str(), qry - 1, 1);
        }
    }
    printf("+-------------------------------+\n");
    printf("| Result                        |\n");
    printf("+-------------------------------+\n");
    printf("| Number of optimal moves = %-2d  |\n", optimal_move_count);
    printf("| Your score = %-4lld             |\n", score_table[optimal_move_count]);
    printf("+-------------------------------+\n");
}