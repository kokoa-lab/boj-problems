everYouNeedSomebody #OfficialMusicVideo","commandRuns":[{"startIndex":180,"length":16,"onTap":{"innertubeCommand":{"clickTrackingParams":"CMsBENzXBBhWIhMI9fmLhcf1kwMVFkE4BR1_xDZlygEE6i2urg==","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/rickastleynever","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag","params":"6gUTCg9yaWNrYXN0bGV5bmV2ZXIYAQ%3D%3D"}}},"loggingDirectives":{"trackingParams":"CMsBENzXBBhWIhMI9fmLhcf1kwMVFkE4BR1_xDZl"}},{"startIndex":197,"length":33,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBgQ040EGAYiEwj1-YuFx_WTAxUWQTgFHX_ENmVIxLuBrb2YjoZ1ygEE6i2urg==","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbDVmakxhR2pmS2NaSUw5RXJfNkszU1dSZkRyQXxBQ3Jtc0trdjdVelNpZ1pzaFc5LXFQa3h3NXJYcDd6eHFXRHFmU0E5bXAta3dadlBXWldQWmd2Yi1xZ3pMQnBxM3VUMlZsek5uRGphR1dNeThyX1JDV2E2SnB4bzNTTzBINVYxWE44ZzFnRmlpVjU2TTVkcGFaOA\u0026q=https%3A%2F%2Flinktr.ee%2Frickastleynever\u0026v=dQw4w9WgXcQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbDVmakxhR2pmS2NaSUw5RXJfNkszU1dSZkRyQXxBQ3Jtc0trdjdVelNpZ1pzaFc5LXFQa3h3NXJYcDd6eHFXRHFmU0E5bXAta3dadlBXWldQWmd2Yi1xZ3pMQnBxM3VUMlZsek5uRGphR1dNeThyX1JDV2E2SnB4bzNTTzBINVYxWE44ZzFnRmlpVjU2TTVkcGFaOA\u0026q=https%3A%2F%2Flinktr.ee%2Frickastleynever\u0026v=dQw4w9WgXcQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startIndex":985,"length":33,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBgQ040EGAYiEwj1-YuFx_WTAxUWQTgFHX_ENmVIxLuBrb2YjoZ1ygEE6i2urg==","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbGZEbmhfbndha3RxRjJLbWhSNFIzNGkwRk1jZ3xBQ3Jtc0trdG16M1FvTzVpNGhnSmZ3Vm5UZXRRZGtmWWlORExJNUFpWFpCWHdYQkRON05ZbUJ1d1Eza21ERUFwaTNkcktSZjFwc0JCWXpIdmJBUU11NGRnVkNrRTJGX1hMOGNIMmN