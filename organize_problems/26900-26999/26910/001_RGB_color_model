<tbody><tr>
<th>Notation
</th>
<th>RGB triplet
</th></tr>
<tr>
<td>Arithmetic
</td>
<td>(1.0, 0.0, 0.0)
</td></tr>
<tr>
<td>Percentage
</td>
<td>(100%, 0%, 0%)
</td></tr>
<tr>
<td>Digital 8-bit per channel
</td>
<td>(255, 0, 0)<br /> #FF0000 (hexadecimal)
</td></tr>
<tr>
<td>Digital 12-bit per channel
</td>
<td>(4095, 0, 0)<br /> #FFF000000
</td></tr>
<tr>
<td>Digital 16-bit per channel
</td>
<td>(65535, 0, 0)<br /> #FFFF00000000
</td></tr>
<tr>
