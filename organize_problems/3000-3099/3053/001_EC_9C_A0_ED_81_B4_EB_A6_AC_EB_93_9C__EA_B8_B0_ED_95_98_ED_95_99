</section><section data-mw-section-id="3" id="mwPQ" aria-labelledby="각주"><div class="mw-heading mw-heading2"><h2 id="각주"><span id=".EA.B0.81.EC.A3.BC" typeof="mw:FallbackId"></span>각주</h2><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="//ko.wikipedia.org/w/index.php?title=%EC%9C%A0%ED%81%B4%EB%A6%AC%EB%93%9C_%EA%B8%B0%ED%95%98%ED%95%99&amp;action=edit&amp;section=3" title="부분 편집: 각주"><span>편집</span></a><span class="mw-editsection-bracket">]</span></span></div>
<div class="mw-references-wrap" typeof="mw:Extension/references" about="#mwt17" id="mwPg" data-mw="{&quot;name&quot;:&quot;references&quot;,&quot;attrs&quot;:{}}"><ol class="mw-references references" id="mwPw"><li about="#cite_note-1" id="cite_note-1" data-mw-footnote-number="1"><span class="mw-cite-backlink" id="mwQA"><a href="#cite_ref-1" rel="mw:referencedBy" id="mwQQ"><span class="mw-linkback-text" id="mwQg">↑</span></a></span> <span id="mw-reference-text-cite_note-1" class="mw-reference-text reference-text">Eves, vol. 1, p. 19</span></li>
<li about="#cite_note-2" id="cite_note-2" data-mw-footnote-number="2"><span class="mw-cite-backlink" id="mwQw"><a href="#cite_ref-2" rel="mw:referencedBy" id="mwRA"><span class="mw-linkback-text" id="mwRQ">↑</span></a></span> <span id="mw-reference-text-cite_note-2" class="mw-reference-text reference-text">Eves (1963), vol. 1, p. 10</span></li>
