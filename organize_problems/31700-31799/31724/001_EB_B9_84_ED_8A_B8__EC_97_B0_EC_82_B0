<pre id="mwUg">    0101
XOR 0011
  = 0110</pre>

<p id="mwUw"><a rel="mw:WikiLink" href="//ko.wikipedia.org/wiki/C_(프로그래밍_언어)" title="C (프로그래밍 언어)" id="mwVA">C</a> / <a rel="mw:WikiLink" href="//ko.wikipedia.org/wiki/C++" title="C++" id="mwVQ">C++</a></p>
<pre id="mwVg">x = y ^ z;</pre>

<p id="mwVw"><a rel="mw:WikiLink" href="//ko.wikipedia.org/wiki/델파이" title="델파이" id="mwWA">델파이</a></p>
<pre id="mwWQ">x := y xor z;</pre>

