#include"testlib.h"
#include<bits/stdc++.h>
using namespace std;
using ll=long long;

struct node{node*l,*r;int x,lc=1,rc=1;};

node* makenode(int x)
{
    node*ptr=new node;
    ptr->x=x;
    return ptr;
}

mt19937 mt;

ll rng(ll range)
{
    ll d=1;
    while(d<range)d*=2;
    while(1)
    {
        ll a=mt()%d;
        if(a<range)return a;
    }
}

void insert(node*rt,int x)
{
    while(1)
    {
        int range=rt->lc+rt->rc;
        ll a=rng(range);
        if(a<rt->lc)
        {
            rt->lc++;
            if(rt->lc==2)
            {
                rt->l=makenode(x);
                return;
            }
            rt=rt->l;
        }
        else
        {
            rt->rc++;
            if(rt->rc==2)
            {
                rt->r=makenode(x);
                return;
            }
            rt=rt->r;
        }
    }
}

void insert2(node*rt,int x)
{
    while(1)
    {
        int range=rt->lc+rt->rc;
        ll a=rng(range);
        if(a>=rt->lc)
        {
            rt->lc++;
            if(rt->lc==2)
            {
                rt->l=makenode(x);
                return;
            }
            rt=rt->l;
        }
        else
        {
            rt->rc++;
            if(rt->rc==2)
            {
                rt->r=makenode(x);
                return;
            }
            rt=rt->r;
        }
    }
}

void clean(node*rt)
{
    if(rt->lc>1)clean(rt->l);
    if(rt->rc>1)clean(rt->r);
    delete rt;
}

void inorder(node*rt,vector<ll>&v)
{
    if(rt->lc>1)inorder(rt->l,v);
    v.push_back(rt->x);
    if(rt->rc>1)inorder(rt->r,v);
}

string answer[]{"Alice","Bob"};

int main(int argc, char ** argv)
{
    registerInteraction(argc, argv);
    mt.seed(inf.readLong(1,1'000'000'000'000'000'000,"seed"));
    cout<<1000<<endl;
    int cntr=0;
    for(int j=0;j<1000;j++)
    {
        cout<<1000<<endl;
        int type=rng(2);
        node*rt=makenode(1);
        if(type==0)
        {
            for(int i=2;i<=1000;i++)insert(rt,i);
        }
        else
        {
            for(int i=2;i<=1000;i++)insert2(rt,i);
        }
        vector<ll>v;
        inorder(rt,v);
        for(int i=0;i<1000;i++)
        {
            cout<<v[i];
            if(i==999)cout<<endl;
            else cout<<" ";
        }
        clean(rt);
        string res=ouf.readToken("Alice|Bob");
        if(res==answer[type])cntr++;
    }
    tout<<cntr<<endl;
    quitf(_ok,"valid passthrough");
}