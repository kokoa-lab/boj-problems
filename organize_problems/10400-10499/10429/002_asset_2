        <div class="sub">
          <div data-delighter class="image delighter-down" style="background-image:url(img/3_iphone_white_side1.png)"></div>
        </div>
        <div class="sub">
          <h2>The Daily Quento</h2>
          <p>Wake up and train your brain with the Daily Quento, a fresh puzzle every day of the week.</p>
          <p><div class="icon daily"></div></p>
          <p>Why not challenge a friend, partner or co-worker to the Daily Quento and see who's best?</p>
        </div>
      </section>
      <div id="get-the-app" class="black-belt">
